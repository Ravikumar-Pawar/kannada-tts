{
    "model": {
        "vocab_size": 150,
        "phoneme_vocab_size": 80,
        "hidden_dim": 256,
        "num_mels": 80,
        "n_fft": 1024,
        "hop_length": 256,
        "win_length": 1024,
        "sample_rate": 22050,
        "f0_min": 70,
        "f0_max": 400,
        "grapheme_encoder": {
            "embedding_dim": 256,
            "num_layers": 4,
            "nhead": 4,
            "ff_dim": 1024,
            "dropout": 0.1
        },
        "phoneme_encoder": {
            "embedding_dim": 256,
            "num_layers": 2,
            "hidden_dim": 256,
            "dropout": 0.1,
            "bidirectional": true
        },
        "fusion_layer": {
            "hidden_dim": 256,
            "dropout": 0.1
        },
        "prosody_encoder": {
            "hidden_dim": 256,
            "num_pitch_bins": 256,
            "num_energy_bins": 256,
            "dropout": 0.1
        },
        "flow_model": {
            "num_flows": 4,
            "num_wavenet_layers": 4,
            "wavenet_hidden_dim": 256,
            "dropout": 0.1
        },
        "decoder": {
            "num_upsample_layers": 4,
            "upsample_scales": [
                8,
                8,
                2,
                2
            ],
            "upsample_kernel_sizes": [
                16,
                16,
                4,
                4
            ],
            "resblock_kernel_sizes": [
                3,
                7,
                11
            ],
            "resblock_dilation_sizes": [
                [
                    1,
                    3,
                    5
                ],
                [
                    1,
                    3,
                    5
                ],
                [
                    1,
                    3,
                    5
                ]
            ],
            "dropout": 0.05
        },
        "discriminator": {
            "num_discriminators": 3,
            "hidden_dim": 256
        }
    },
    "training": {
        "batch_size": 32,
        "num_workers": 4,
        "num_epochs": 100,
        "learning_rate": 2e-4,
        "weight_decay": 1e-6,
        "warmup_steps": 5000,
        "grad_clip_val": 1.0,
        "validation_interval": 5,
        "checkpoint_interval": 5,
        "accumulation_steps": 4,
        "mixed_precision": false,
        "seed": 42
    },
    "loss_weights": {
        "reconstruction": 1.0,
        "kl_divergence": 0.1,
        "adversarial": 1.0,
        "f0": 0.5,
        "energy": 0.1,
        "duration": 0.5
    },
    "optimizer": {
        "name": "AdamW",
        "betas": [
            0.9,
            0.999
        ],
        "eps": 1e-9,
        "weight_decay": 1e-6
    },
    "scheduler": {
        "name": "ExponentialLR",
        "gamma": 0.9999
    },
    "data": {
        "dataset_path": "path/to/dataset/",
        "wav_folder": "wav",
        "txt_folder": "txt",
        "max_audio_length": 50000,
        "min_audio_length": 1000,
        "trim_silence": true
    },
    "inference": {
        "temperature": 0.667,
        "top_k": 250,
        "top_p": 0.9,
        "num_speakers": 1,
        "speaker_id": 0
    },
    "logging": {
        "log_dir": "logs/",
        "checkpoint_dir": "checkpoints/",
        "tensorboard": true,
        "log_interval": 100,
        "save_best_model": true
    }
}